{
  "name": "necronomicon-compendi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "node --test tests/*.test.js",
    "qa": "node qa-runner.mjs",
    "qa:smoke": "node qa-runner.mjs smoke && node capture-runner.mjs smoke",
    "qa:functional": "node qa-runner.mjs functional",
    "qa:ui": "node qa-runner.mjs ui",
    "qa:edit": "node qa-runner.mjs edit",
    "qa:persistence": "node qa-runner.mjs persistence",
    "capture": "node capture-runner.mjs",
    "capture:changed": "node capture-runner.mjs changed",
    "capture:smoke": "node capture-runner.mjs smoke",
    "verify:fast": "npm run build && npm run test:unit",
    "debug:status": "node debug-status.mjs"
  },
  "devDependencies": {
    "vite": "^7.1.0"
  }
}
